<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- TV Theme (Keep Leanback) -->
    <style name="Theme.Aruvi.TV" parent="Theme.Leanback">
        <item name="android:colorPrimary">@color/primary</item>
        <item name="android:colorPrimaryDark">@color/primary_variant</item>
        <item name="android:colorAccent">@color/secondary</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:colorBackground">@color/background</item>
    </style>

    <!-- Mobile Theme (AppCompat for MediaRouter compatibility) -->
    <style name="Theme.Aruvi.Mobile" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:colorPrimary">@color/primary</item>
        <item name="android:colorPrimaryDark">@color/primary_variant</item>
        <item name="android:colorAccent">@color/secondary</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:colorBackground">@color/background</item>

        <!-- AppCompat compatibility (required for MediaRouter) -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_variant</item>
        <item name="colorAccent">@color/secondary</item>
    </style>

    <!-- Deprecated name for compatibility with existing code if any -->
    <style name="Theme.TelegramTV" parent="Theme.Aruvi.TV" />
</resources>
